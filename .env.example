# MapCoDoc Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# REQUIRED FOR FULL PIPELINE
# =============================================================================

# OpenAI API Key for LLM-based documentation structuring (Step 5)
# Get your API key from: https://platform.openai.com/api-keys
# If not set, LLM structuring is automatically skipped and raw docs are stored.
OPENAI_API_KEY=sk-your-api-key-here

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Proxy configuration for web documentation crawling
# Useful if you're behind a corporate firewall or need to rotate IPs
# Format: single proxy or comma-separated list
# Examples:
#   MAPCODOC_PROXIES=http://proxy.example.com:8080
#   MAPCODOC_PROXIES=http://user:pass@proxy1:8080,http://proxy2:8080
# MAPCODOC_PROXIES=

# =============================================================================
# FEATURE FLAGS (Advanced)
# =============================================================================
# Override default feature flag states (1 to enable, 0 to disable)
# See docs/features.md for details on each flag

# Enable NetworkX-based graph analysis for advanced API resolution (default: 0)
# MAPCODOC_FEATURE_GRAPH_ANALYSIS=0

# Enable dynamic __all__ evaluation in isolated venv (default: 0)
# MAPCODOC_FEATURE_DYNAMIC_ALL_EVALUATION=0

# Enable call graph tracking (requires GRAPH_ANALYSIS, default: 0)
# MAPCODOC_FEATURE_CALL_GRAPH_ANALYSIS=0

# Enable incremental watch mode for file changes (default: 0)
# MAPCODOC_FEATURE_INCREMENTAL_WATCH_MODE=0
