# Documentation artifacts (keep folders, ignore contents)
doc_processor/doc_artifacts/crawled_URLs/*
!doc_processor/doc_artifacts/crawled_URLs/.gitkeep

doc_processor/doc_artifacts/local_doc/*
!doc_processor/doc_artifacts/local_doc/.gitkeep

