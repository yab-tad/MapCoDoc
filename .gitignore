!doc_processor/doc_artifacts/postprocessed_doc/.gitkeep

doc_processor/doc_artifacts/preprocessed_doc/*
!doc_processor/doc_artifacts/preprocessed_doc/.gitkeep

doc_processor/doc_artifacts/scraped_doc/*
!doc_processor/doc_artifacts/scraped_doc/.gitkeep

doc_processor/doc_artifacts/structured_doc/*
!doc_processor/doc_artifacts/structured_doc/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Build artifacts
build/
dist/
*.egg-info/
.coverage

