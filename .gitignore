# Environment variables (contains secrets)
.env

# Test files
doc_processor/testing_doc.py
mapcodoc_db/test_db.py
test_repo_1/
tests/*.txt
tests/*.json

# Tests and replication package components
eval_files/*
tools/*
DATA_LICENSES.md
REPRODUCE.md
mapcodoc-replication/*


# Output directory (keep folder, ignore contents)
mapcodoc_output/*
